# Default values
defaults
port        	587
tls         	on
tls_starttls	on

# Brevo SMTP relay
account     	brevo
host        	smtp-relay.brevo.com
from        	<from address>
auth        	on
user        	<user>
password    	<password>

# Default account
account default : brevo

# Log
logfile     	~/.msmtp.log
